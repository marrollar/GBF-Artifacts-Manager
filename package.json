{
  "name": "gbf-artis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-watch",
    "build": "next build && npm run lint:build",
    "lint:build": "mv out/_next out/assets && rm out/__next.*.txt && rm -rf out/_not-found && cp -a chrome-extension/* out/",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "gbf-artis": "link:",
    "next": "16.1.2",
    "node-html-parser": "^7.1.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-resizable-panels": "^4.7.6",
    "use-debounce": "^10.1.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/chrome": "^0.1.38",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "daisyui": "^5.5.14",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.8",
    "npm-watch": "^0.13.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "watch": {
    "build": {
      "patterns": [
        ".",
        "app/**",
        "public/**"
      ],
      "ignore": [
        "out",
        "node_modules",
        ".next",
        "chrome-extension"
      ],
      "extensions": [
        "js",
        "json",
        "lock",
        "tsx",
        "ts"
      ]
    }
  }
}
